# aMaze platform env — copy to `.env` and fill in.
# `.env` is gitignored. NEVER commit real keys.

# ── LLM providers (passed through to spawned agent containers) ─────────────
OPENAI_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_KEY=

# ── External tool APIs (passed through to spawned MCP containers) ──────────
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false

# ── MCP: demo sql_tool wiring (optional) ───────────────────────────────────
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ── Platform wiring ────────────────────────────────────────────────────────
# Where spawned sibling containers reach the proxy. Compose DNS gives them
# `amaze` as the hostname of the platform container.
AMAZE_PROXY_URL=http://amaze:8080

# Docker network names (must match the names in docker/compose.networks.yml
# after the `name:` prefix is applied by compose).
AMAZE_AGENT_NETWORK=amaze_amaze-agent-net
AMAZE_MCP_NETWORK=amaze_amaze-mcp-net

# Named volume holding the mitmproxy CA. Declared in docker-compose.yml.
AMAZE_PROXY_CA_VOLUME=amaze-proxy-ca
