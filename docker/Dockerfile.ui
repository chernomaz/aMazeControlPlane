# aMaze UI — multi-stage build (Node → nginx static serve).
#
# Stage 1: install deps + build the React app.
# Stage 2: serve the built bundle behind nginx, proxying /api/* to the
#          orchestrator container at amaze:8001.
#
# Build:  docker build -f docker/Dockerfile.ui -t amaze-ui .
# Run:    docker run -p 5173:80 --network amaze_default amaze-ui

FROM node:20-alpine AS builder
WORKDIR /app

COPY services/ui/package.json ./
RUN npm install --no-audit --no-fund

COPY services/ui/ ./
RUN npm run build


FROM nginx:alpine
COPY services/ui/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
