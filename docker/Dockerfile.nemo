# NEMO base container image for aMaze Control Plane agents (Phase 8A).
#
# Minimal Python environment that:
#   - Registers with the Orchestrator on startup
#   - Waits for policy assignment before serving traffic (returns 503 until RUNNING)
#   - Routes all outbound HTTP through the Envoy proxy via HTTP_PROXY
#
# Phase 8B adds patched openai/anthropic/mcp SDKs and the LiteLLM/A2A sidecars.
FROM python:3.12-slim

RUN pip install --no-cache-dir \
    "fastapi==0.115.0" \
    "uvicorn[standard]==0.30.6" \
    "httpx==0.27.2"

WORKDIR /app
COPY docker/nemo_agent.py /app/nemo_agent.py

ENV PYTHONUNBUFFERED=1

EXPOSE 8080 9002

CMD ["python", "/app/nemo_agent.py"]
